<div class="istikama-section" dir="auto">
    <div class="isti-section-header">
        <i class="fa fa-life-ring"></i> {{#str}}menu_support, local_istikama_admin{{/str}}
    </div>

    <div class="isti-kpi-grid">
        <div class="isti-kpi-card">
            <div class="isti-kpi-content" style="width:100%">
                <div class="isti-kpi-label" style="margin-bottom:4px">
                    <i class="fa fa-headset" style="color:var(--primary-color)"></i>
                </div>
                <h5 style="font-size:1rem;font-weight:700;margin:0 0 6px 0;color:var(--text-color)">Support contact settings</h5>
                <p class="isti-kpi-label" style="margin-bottom:12px">Configure emails, support page and contact channels.</p>
                <a class="isti-btn isti-btn-primary isti-btn-sm" href="{{supportcontacturl}}">
                    <i class="fa fa-cog"></i> Open settings
                </a>
            </div>
        </div>

        <div class="isti-kpi-card">
            <div class="isti-kpi-content" style="width:100%">
                <div class="isti-kpi-label" style="margin-bottom:4px">
                    <i class="fa fa-bug" style="color:var(--warning)"></i>
                </div>
                <h5 style="font-size:1rem;font-weight:700;margin:0 0 6px 0;color:var(--text-color)">Logs and diagnostics</h5>
                <p class="isti-kpi-label" style="margin-bottom:12px">Track reports and incidents from logs.</p>
                <a class="isti-btn isti-btn-outline isti-btn-sm" href="{{managelogurl}}">
                    <i class="fa fa-clipboard-list"></i> Open logs
                </a>
            </div>
        </div>

        <div class="isti-kpi-card">
            <div class="isti-kpi-content" style="width:100%">
                <div class="isti-kpi-label" style="margin-bottom:4px">
                    <i class="fa fa-users-cog" style="color:var(--success)"></i>
                </div>
                <h5 style="font-size:1rem;font-weight:700;margin:0 0 6px 0;color:var(--text-color)">User administration</h5>
                <p class="isti-kpi-label" style="margin-bottom:12px">Go directly to users management workflow.</p>
                <a class="isti-btn isti-btn-secondary isti-btn-sm" href="{{usersurl}}">
                    <i class="fa fa-external-link-alt"></i> Open users page
                </a>
            </div>
        </div>
    </div>
</div>
