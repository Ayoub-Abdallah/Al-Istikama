{{!
    Reports dashboard — modern, role-aware layout.

    Sections (in order, each conditional on the user's tier):
      * Season banner (selector + status)
      * Executive Summary (KPI tiles, brand-colored only)
      * Key Insights (auto-generated narrative)
      * Section cards — engagement, schools, content, classes, students
      * Empty states that explain WHY data is missing + suggest an action
    Charts use Chart.js, themed with brand colors. Dark-mode aware via the
    theme's CSS variables.
}}
<div class="istikama-reports-dashboard" dir="auto">

{{! ─────────────────────────────────────────────────────────────────────── }}
{{! SEASON BANNER                                                          }}
{{! ─────────────────────────────────────────────────────────────────────── }}
{{#season_banner}}
<div class="rpt-season-banner">
    <div class="rpt-season-banner-meta">
        <span class="rpt-season-banner-label">{{label}}</span>
        <span class="rpt-season-banner-name">
            {{name}}
            {{#status_label}}<span class="rpt-season-banner-state {{status_class}}">{{status_label}}</span>{{/status_label}}
        </span>
    </div>
    {{#picker_options.length}}
    <select class="rpt-season-banner-select" onchange="if(this.value) window.location.href=this.value">
        {{#picker_options}}
        <option value="{{url}}"{{#selected}} selected{{/selected}}>{{label}}</option>
        {{/picker_options}}
    </select>
    {{/picker_options.length}}
</div>
{{/season_banner}}


