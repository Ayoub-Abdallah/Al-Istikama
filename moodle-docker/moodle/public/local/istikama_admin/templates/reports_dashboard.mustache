{{! Chart.js — themed + season-aware                                       }}
{{! ─────────────────────────────────────────────────────────────────────── }}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    if (typeof Chart === 'undefined') return;

    // Pull theme tokens so charts respect light/dark mode.
    var root = getComputedStyle(document.documentElement);
    var brand   = root.getPropertyValue('--primary-color').trim() || '#006bff';
    var brandSoft = 'rgba(0, 107, 255, 0.10)';
    var text    = root.getPropertyValue('--text-color').trim() || '#0f172a';
    var muted   = root.getPropertyValue('--text-secondary').trim() || '#64748b';
    var border  = root.getPropertyValue('--card-border').trim() || '#e2e8f0';

    Chart.defaults.font.family = root.getPropertyValue('--font-dashboard').trim()
                              || "Inter, system-ui, sans-serif";
    Chart.defaults.color = muted;

    var brandPalette = [brand, '#10b981', '#f59e0b', '#a855f7', '#06b6d4', '#3389ff', '#64748b', '#8b5cf6'];
    var grid = { color: border + '40' };

    function lineChart(canvasId, data, label) {
        var el = document.getElementById(canvasId);
        if (!el || !data || !data.length) return;
        new Chart(el.getContext('2d'), {
            type: 'line',
            data: {
                labels: data.map(function(d) { return d.label; }),
                datasets: [{
                    label: label,
                    data: data.map(function(d) { return d.value; }),
                    borderColor: brand,
                    backgroundColor: brandSoft,
                    fill: true,
                    tension: 0.35,
                    pointRadius: 3,
                    pointBackgroundColor: brand,
                    borderWidth: 2,
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: grid, ticks: { color: muted } },
                    x: { grid: { display: false }, ticks: { color: muted } }
                }
            }
        });
    }

    function doughnutChart(canvasId, data) {
        var el = document.getElementById(canvasId);
        if (!el || !data || !data.length) return;
        new Chart(el.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: data.map(function(d) { return d.label; }),
                datasets: [{
                    data: data.map(function(d) { return d.value; }),
                    backgroundColor: brandPalette,
                    borderWidth: 0,
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom', labels: { color: text } } },
                cutout: '65%',
            }
        });
    }

    function barChart(canvasId, data, label) {
        var el = document.getElementById(canvasId);
        if (!el || !data || !data.length) return;
        new Chart(el.getContext('2d'), {
            type: 'bar',
            data: {
                labels: data.map(function(d) { return d.label; }),
                datasets: [{
                    label: label,
                    data: data.map(function(d) { return d.value; }),
                    backgroundColor: brand,
                    borderRadius: 6,
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: grid, ticks: { color: muted } },
                    x: { grid: { display: false }, ticks: { color: muted } }
                }
            }
        });
    }

    {{#is_admin}}
    try { lineChart('rptLoginTrendChart', {{{login_trend}}}, 'Daily logins'); } catch(e) {}
    try { doughnutChart('rptContentTypeChart',   {{{content_by_type_json}}});   } catch(e) {}
    try { doughnutChart('rptContentStatusChart', {{{content_by_status_json}}}); } catch(e) {}
    try { barChart('rptUploadTrendChart', {{{upload_trend_json}}}, 'Uploads'); } catch(e) {}
    {{/is_admin}}

    {{#is_manager}}
    try { lineChart('mrptLoginTrendChart', {{{login_trend}}}, 'Daily logins'); } catch(e) {}
    try { doughnutChart('mrptContentTypeChart',   {{{content_by_type_json}}});   } catch(e) {}
    try { doughnutChart('mrptContentStatusChart', {{{content_by_status_json}}}); } catch(e) {}
    {{/is_manager}}

    {{#is_teacher}}
    // ── Student table interactions ──
    var s = document.getElementById('rptStudentSearch');
    if (s) {
        s.addEventListener('input', function() {
            var q = this.value.toLowerCase().trim();
            document.querySelectorAll('#rptStudentTable tbody tr').forEach(function(row) {
                var n = (row.getAttribute('data-name') || '').toLowerCase();
                row.style.display = n.indexOf(q) >= 0 ? '' : 'none';
            });
        });
    }
    document.querySelectorAll('#rptStudentTable th[data-sort]').forEach(function(th) {
        th.addEventListener('click', function() {
            var key = th.getAttribute('data-sort');
            var tbody = document.querySelector('#rptStudentTable tbody');
            var rows = Array.from(tbody.querySelectorAll('tr'));
            var asc = th.dataset.asc !== 'true';
            th.dataset.asc = asc;
            rows.sort(function(a, b) {
                var va = key === 'name'
                    ? (a.getAttribute('data-name') || '')
                    : parseFloat(a.getAttribute('data-' + key) || '0');
                var vb = key === 'name'
                    ? (b.getAttribute('data-name') || '')
                    : parseFloat(b.getAttribute('data-' + key) || '0');
                if (typeof va === 'string') return asc ? va.localeCompare(vb) : vb.localeCompare(va);
                return asc ? va - vb : vb - va;
            });
            rows.forEach(function(r) { tbody.appendChild(r); });
        });
    });
    {{/is_teacher}}

    // ── Dynamic color for attendance/grade pills ──
    document.querySelectorAll('.rpt-att-pill, .rpt-grade-pill').forEach(function(pill) {
        var v = parseFloat(pill.getAttribute('data-val') || '0');
        if (v >= 80)      { pill.style.background = 'rgba(16,185,129,0.18)';  pill.style.color = '#047857'; }
        else if (v >= 50) { pill.style.background = 'rgba(245,158,11,0.18)';  pill.style.color = '#92400e'; }
        else              { pill.style.background = 'rgba(239,68,68,0.18)';   pill.style.color = '#991b1b'; }
    });
});
</script>
