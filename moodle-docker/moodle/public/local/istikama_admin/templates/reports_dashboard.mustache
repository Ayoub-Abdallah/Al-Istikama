{{! Styles — scoped to .istikama-reports-dashboard                         }}
{{! ─────────────────────────────────────────────────────────────────────── }}
<style>
.istikama-reports-dashboard {
    --rpt-bg: var(--card-bg, #ffffff);
    --rpt-text: var(--text-color, #0f172a);
    --rpt-muted: var(--text-secondary, #64748b);
    --rpt-border: var(--card-border, #e2e8f0);
    --rpt-primary: var(--primary-color, #006bff);
    --rpt-primary-dark: var(--primary-dark, #0052cc);
    --rpt-primary-soft: rgba(0, 107, 255, 0.08);
    --rpt-success: #10b981;
    --rpt-success-soft: rgba(16, 185, 129, 0.12);
    --rpt-warning: #f59e0b;
    --rpt-warning-soft: rgba(245, 158, 11, 0.12);
    --rpt-danger: #ef4444;
    --rpt-danger-soft: rgba(239, 68, 68, 0.12);
}

/* Season banner */
.rpt-season-banner {
    background: var(--rpt-bg);
    border: 1px solid var(--rpt-border);
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
}
.rpt-season-banner-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.6px; color: var(--rpt-muted); font-weight: 600; display: block; }
.rpt-season-banner-name { font-size: 1.05rem; font-weight: 700; color: var(--rpt-text); display: flex; align-items: center; gap: 10px; margin-top: 3px; }
.rpt-season-banner-state {
    font-size: 0.7rem; font-weight: 600; padding: 3px 9px; border-radius: 999px;
    background: var(--rpt-primary-soft); color: var(--rpt-primary);
    text-transform: uppercase; letter-spacing: 0.4px;
}
.rpt-season-banner-state.active   { background: var(--rpt-success-soft); color: var(--rpt-success); }
.rpt-season-banner-state.legacy,
.rpt-season-banner-state.closed   { background: rgba(100, 116, 139, 0.12); color: var(--rpt-muted); }
.rpt-season-banner-state.upcoming { background: var(--rpt-primary-soft); color: var(--rpt-primary); }
.rpt-season-banner-select {
    padding: 9px 14px; border: 1px solid var(--rpt-border); border-radius: 9px;
    background: var(--rpt-bg); color: var(--rpt-text); font-weight: 500; min-width: 240px; cursor: pointer;
}

/* Section structure */
.rpt-section { margin-bottom: 28px; }
.rpt-section-head { margin-bottom: 14px; display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
.rpt-section-title {
    margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--rpt-text);
    display: flex; align-items: center; gap: 10px;
}
.rpt-section-title i { color: var(--rpt-primary); font-size: 0.95rem; }
.rpt-section-sub { margin: 4px 0 0; color: var(--rpt-muted); font-size: 0.84rem; }

/* KPI tiles */
.rpt-kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
}
.rpt-kpi {
    background: var(--rpt-bg);
    border: 1px solid var(--rpt-border);
    border-radius: 12px;
    padding: 16px 18px;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: border-color .12s ease, box-shadow .12s ease;
}
.rpt-kpi:hover { border-color: var(--rpt-primary); box-shadow: 0 4px 14px rgba(0, 107, 255, 0.08); }
.rpt-kpi-icon {
    width: 44px; height: 44px;
    border-radius: 11px;
    background: var(--rpt-primary-soft);
    color: var(--rpt-primary);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
}
.rpt-kpi-body { flex: 1; min-width: 0; }
.rpt-kpi-label { font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.45px; color: var(--rpt-muted); font-weight: 600; }
.rpt-kpi-value { font-size: 1.5rem; font-weight: 700; color: var(--rpt-text); margin-top: 2px; line-height: 1.1; }

/* Insights */
.rpt-insights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 10px;
}
.rpt-insight {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 12px 14px;
    background: var(--rpt-primary-soft);
    border: 1px solid transparent;
    border-radius: 10px;
    font-size: 0.88rem;
    color: var(--rpt-text);
    line-height: 1.45;
}
.rpt-insight-icon { color: var(--rpt-primary); font-size: 1rem; margin-top: 1px; flex-shrink: 0; }
.rpt-insight.rpt-tone-positive { background: var(--rpt-success-soft); }
.rpt-insight.rpt-tone-positive .rpt-insight-icon { color: var(--rpt-success); }
.rpt-insight.rpt-tone-warn { background: var(--rpt-warning-soft); }
.rpt-insight.rpt-tone-warn .rpt-insight-icon { color: var(--rpt-warning); }
.rpt-insight.rpt-tone-danger { background: var(--rpt-danger-soft); }
.rpt-insight.rpt-tone-danger .rpt-insight-icon { color: var(--rpt-danger); }

/* Cards */
.rpt-card {
    background: var(--rpt-bg);
    border: 1px solid var(--rpt-border);
    border-radius: 12px;
    padding: 18px 20px;
}
.rpt-card-title {
    font-size: 0.95rem; font-weight: 700; color: var(--rpt-text);
    margin: 0 0 14px;
    display: flex; align-items: center; gap: 8px;
}
.rpt-card-title i { color: var(--rpt-primary); }
.rpt-grid-2 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 16px;
}

/* Charts */
.rpt-chart-wrap { position: relative; height: 320px; }
.rpt-chart-sm { height: 240px; }

/* Tables — match the platform's unified blue-header data table. */
.rpt-table-wrap { overflow-x: auto; border-radius: 12px; }
.rpt-table { width: 100%; border-collapse: separate; border-spacing: 0; }
.rpt-table thead th {
    background: linear-gradient(180deg, #006bff 0%, #0058d6 100%);
    color: #ffffff;
    text-align: left;
    padding: 12px 16px;
    font-size: 0.76rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 0;
    white-space: nowrap;
}
.rpt-table tbody td {
    padding: 12px 16px;
    border-top: 1px solid var(--rpt-border);
    color: var(--rpt-text);
    font-size: 0.88rem;
    vertical-align: middle;
}
.rpt-table tbody tr:first-child td { border-top: 0; }
.rpt-table tbody tr:hover { background: var(--rpt-primary-soft); }
.rpt-table .rpt-right { text-align: right; }
.rpt-table, .rpt-table th, .rpt-table td { border-left: 0 !important; border-right: 0 !important; }
.rpt-sortable { cursor: pointer; }
.rpt-sortable:after { content: ' ↕'; opacity: 0.4; font-size: 0.8em; }
.rpt-table-toolbar { padding: 0 0 12px; }
.rpt-input {
    padding: 9px 13px; border: 1px solid var(--rpt-border); border-radius: 8px;
    background: var(--rpt-bg); color: var(--rpt-text); font-size: 0.88rem;
    width: 320px; max-width: 100%;
}
.rpt-input:focus { outline: 0; border-color: var(--rpt-primary); box-shadow: 0 0 0 3px rgba(0, 107, 255, 0.12); }

/* Pills */
.rpt-pill {
    display: inline-block; padding: 3px 10px; border-radius: 999px;
    font-size: 0.74rem; font-weight: 600; white-space: nowrap;
}
.rpt-pill-primary { background: var(--rpt-primary-soft); color: var(--rpt-primary); }
.rpt-pill-neutral { background: rgba(100, 116, 139, 0.12); color: var(--rpt-muted); }
.rpt-pill-info    { background: rgba(59, 130, 246, 0.14); color: #1d4ed8; }

/* Progress bars */
.rpt-progress {
    display: inline-block; vertical-align: middle;
    width: 80px; height: 6px;
    border-radius: 4px;
    background: rgba(100, 116, 139, 0.18);
    overflow: hidden;
    margin-right: 8px;
}
.rpt-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--rpt-primary), var(--rpt-primary-dark));
    border-radius: 4px;
}
.rpt-progress-label { font-size: 0.8rem; font-weight: 600; color: var(--rpt-text); }
.rpt-muted { color: var(--rpt-muted); }

/* Empty states */
.rpt-empty {
    background: var(--rpt-bg);
    border: 1.5px dashed var(--rpt-border);
    border-radius: 12px;
    padding: 36px 28px;
    text-align: center;
}
.rpt-empty-icon { font-size: 2.4rem; color: var(--rpt-muted); opacity: 0.5; display: block; margin-bottom: 12px; }
.rpt-empty-title { font-size: 1.02rem; font-weight: 700; color: var(--rpt-text); margin: 0 0 6px; }
.rpt-empty-msg { color: var(--rpt-muted); font-size: 0.88rem; max-width: 60ch; margin: 0 auto 14px; line-height: 1.55; }
.rpt-empty-cta {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--rpt-primary); color: #fff;
    padding: 9px 18px; border-radius: 9px; text-decoration: none;
    font-weight: 600; font-size: 0.86rem; transition: background .12s ease;
}
.rpt-empty-cta:hover { background: var(--rpt-primary-dark); color: #fff; text-decoration: none; }
.rpt-empty-inline { padding: 24px; text-align: center; color: var(--rpt-muted); font-size: 0.88rem; }

/* Dynamic attendance/grade pills */
.rpt-att-pill,
.rpt-grade-pill { background: rgba(100, 116, 139, 0.15); color: var(--rpt-text); }
</style>

