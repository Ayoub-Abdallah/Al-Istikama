<!-- ═══ DASHBOARD JS ═══ -->
<script>
/**
 * Istikama dashboard wiring.
 *
 * Every element lookup is null-guarded and every block is wrapped in
 * try/catch so a missing element in one feature can never break another.
 * The whole runner waits for DOMContentLoaded; if the script tag is loaded
 * after DOMContentLoaded already fired we run immediately.
 */
(function() {
    function safeRun(fn) {
        try { fn(); } catch (err) {
            if (window.console && console.warn) {
                console.warn('[istikama] dashboard JS guarded error:', err);
            }
        }
    }

    function boot() {
        var sidebar    = document.getElementById('istiSidebar');
        var overlay    = document.getElementById('istiSidebarOverlay');
        var toggle     = document.getElementById('istiSidebarToggle');
        var darkToggle = document.getElementById('istiDarkModeToggle');
        var isMobile   = window.innerWidth <= 1024;

        // ── Sidebar toggle ────────────────────────────────────────────────
        safeRun(function() {
            if (!toggle) { return; }
            toggle.addEventListener('click', function() {
                if (!sidebar) { return; }
                if (isMobile) {
                    sidebar.classList.toggle('mobile-open');
                    if (overlay) { overlay.classList.toggle('visible'); }
                } else {
                    sidebar.classList.toggle('collapsed');
                    try {
                        localStorage.setItem('isti-sidebar-collapsed',
                            sidebar.classList.contains('collapsed') ? '1' : '0');
                    } catch (e) { /* localStorage may be disabled */ }
                }
            });
        });

        // ── Mobile overlay click ──────────────────────────────────────────
        safeRun(function() {
            if (!overlay) { return; }
            overlay.addEventListener('click', function() {
                if (sidebar) { sidebar.classList.remove('mobile-open'); }
                overlay.classList.remove('visible');
            });
        });

        // ── Restore sidebar state from localStorage ───────────────────────
        safeRun(function() {
            if (!sidebar || isMobile) { return; }
            try {
                if (localStorage.getItem('isti-sidebar-collapsed') === '1') {
                    sidebar.classList.add('collapsed');
                }
            } catch (e) { /* localStorage may be disabled */ }
        });

        // ── Responsive resize handler ─────────────────────────────────────
        safeRun(function() {
            window.addEventListener('resize', function() {
                isMobile = window.innerWidth <= 1024;
                if (!isMobile) {
                    if (sidebar) { sidebar.classList.remove('mobile-open'); }
                    if (overlay) { overlay.classList.remove('visible'); }
                }
            });
        });

        // ── Dark mode toggle ──────────────────────────────────────────────
        safeRun(function() {
            if (!darkToggle) { return; }
            var isDark = false;
            try { isDark = localStorage.getItem('isti-dark-mode') === '1'; }
            catch (e) { /* localStorage may be disabled */ }
            var darkIcon = darkToggle.querySelector('i');
            if (isDark && document.body) {
                document.body.classList.add('dark-mode');
                if (darkIcon) { darkIcon.className = 'fa fa-sun'; }
            }
            darkToggle.addEventListener('click', function() {
                if (!document.body) { return; }
                document.body.classList.toggle('dark-mode');
                var nowDark = document.body.classList.contains('dark-mode');
                try { localStorage.setItem('isti-dark-mode', nowDark ? '1' : '0'); }
                catch (e) { /* localStorage may be disabled */ }
                var ic = darkToggle.querySelector('i');
                if (ic) { ic.className = nowDark ? 'fa fa-sun' : 'fa fa-moon'; }
            });
        });

    // ──────────────────────────────────────────────────────────────
    // Teacher: intercept Moodle's activity chooser "+" button and
    // show our custom 2-option modal (Library content / Quiz).
    // ──────────────────────────────────────────────────────────────
    safeRun(function() {
        if (!document.body) { return; }
        var bodyTier = document.body.getAttribute('data-istikama-tier') || '';
        if (bodyTier !== 'teacher' && bodyTier !== 'teacher_creator') {
            return;
        }

        var addModalEl = null;
        var pendingCtx = null;

        var courseIdFromContext = function() {
            // Try Moodle's M.cfg first, then body class "course-{id}", then URL ?id=.
            if (window.M && M.cfg && M.cfg.courseId) { return String(M.cfg.courseId); }
            var bodyClass = (document.body && document.body.className) || '';
            var m = bodyClass.match(/(?:^|\s)course-(\d+)/);
            if (m) { return m[1]; }
            var u = new URL(window.location.href);
            var id = u.searchParams.get('id');
            if (id && /course\/view\.php/.test(u.pathname)) { return id; }
            return '';
        };

        var _istiM = {
            title:      "{{#str}}addlesson_title, local_istikama_admin{{/str}}",
            libTitle:   "{{#str}}addlesson_library_title, local_istikama_admin{{/str}}",
            libDesc:    "{{#str}}addlesson_library_desc, local_istikama_admin{{/str}}",
            quizTitle:  "{{#str}}addlesson_quiz_title, local_istikama_admin{{/str}}",
            quizDesc:   "{{#str}}addlesson_quiz_desc, local_istikama_admin{{/str}}",
            forumTitle: "{{#str}}addlesson_forum_title, local_istikama_admin{{/str}}",
            forumDesc:  "{{#str}}addlesson_forum_desc, local_istikama_admin{{/str}}"
        };
        var buildModal = function() {
            if (addModalEl) { return; }
            addModalEl = document.createElement('div');
            addModalEl.className = 'isti-addmodal-backdrop';
            addModalEl.setAttribute('style',
                'display:none;position:fixed;inset:0;z-index:1100;' +
                'background:rgba(15,23,42,.55);align-items:center;justify-content:center;');
            addModalEl.innerHTML =
                '<div class="isti-addmodal-dialog" role="dialog" aria-modal="true" ' +
                'style="background:#fff;border-radius:18px;width:min(620px,95vw);' +
                'box-shadow:0 20px 60px rgba(0,0,0,.25);overflow:hidden;">' +
                  '<div class="isti-addmodal-header" style="padding:18px 22px;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;justify-content:space-between">' +
                    '<h5 style="margin:0;font-weight:700;color:#1e293b;font-size:1.05rem"><i class="fa fa-plus-circle" style="color:#006bff;margin-right:6px"></i> ' + _istiM.title + '</h5>' +
                    '<button type="button" class="isti-addmodal-close" aria-label="Close" style="background:none;border:none;font-size:1.4rem;color:#64748b;cursor:pointer;line-height:1">&times;</button>' +
                  '</div>' +
                  '<div class="isti-addmodal-body" style="padding:20px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">' +
                    '<a href="#" data-isti-add="library" class="isti-addmodal-option" style="display:block;padding:20px 16px;border:1.5px solid #e2e8f0;border-radius:14px;cursor:pointer;background:#fff;text-decoration:none;color:inherit">' +
                      '<span style="display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:12px;font-size:1.3rem;margin-bottom:12px;background:#eff6ff;color:#006bff"><i class="fa fa-folder-open"></i></span>' +
                      '<strong style="display:block;color:#1e293b;font-size:.92rem;margin-bottom:5px">' + _istiM.libTitle + '</strong>' +
                      '<span style="color:#64748b;font-size:.82rem;line-height:1.45">' + _istiM.libDesc + '</span>' +
                    '</a>' +
                    '<a href="#" data-isti-add="quiz" class="isti-addmodal-option" style="display:block;padding:20px 16px;border:1.5px solid #e2e8f0;border-radius:14px;cursor:pointer;background:#fff;text-decoration:none;color:inherit">' +
                      '<span style="display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:12px;font-size:1.3rem;margin-bottom:12px;background:#f0fdf4;color:#10b981"><i class="fa fa-question-circle"></i></span>' +
                      '<strong style="display:block;color:#1e293b;font-size:.92rem;margin-bottom:5px">' + _istiM.quizTitle + '</strong>' +
                      '<span style="color:#64748b;font-size:.82rem;line-height:1.45">' + _istiM.quizDesc + '</span>' +
                    '</a>' +
                    '<a href="#" data-isti-add="forum" class="isti-addmodal-option" style="display:block;padding:20px 16px;border:1.5px solid #e2e8f0;border-radius:14px;cursor:pointer;background:#fff;text-decoration:none;color:inherit">' +
                      '<span style="display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:12px;font-size:1.3rem;margin-bottom:12px;background:#fdf4ff;color:#a855f7"><i class="fa fa-comments"></i></span>' +
                      '<strong style="display:block;color:#1e293b;font-size:.92rem;margin-bottom:5px">' + _istiM.forumTitle + '</strong>' +
                      '<span style="color:#64748b;font-size:.82rem;line-height:1.45">' + _istiM.forumDesc + '</span>' +
                    '</a>' +
                  '</div>' +
                '</div>';
            if (document.body) { document.body.appendChild(addModalEl); }

            addModalEl.addEventListener('click', function(e) {
                if (e.target === addModalEl) { hideModal(); return; }
                if (e.target && e.target.closest && e.target.closest('.isti-addmodal-close')) {
                    hideModal(); return;
                }
                var opt = e.target && e.target.closest && e.target.closest('[data-isti-add]');
                if (!opt) { return; }
                e.preventDefault();
                routeAddAction(opt.getAttribute('data-isti-add'));
            });
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && addModalEl && addModalEl.style.display !== 'none') {
                    hideModal();
                }
            });
        };

        var showModal = function(ctx) {
            buildModal();
            pendingCtx = ctx;
            if (addModalEl) { addModalEl.style.display = 'flex'; }
        };
        var hideModal = function() {
            if (addModalEl) { addModalEl.style.display = 'none'; }
            pendingCtx = null;
        };

        var routeAddAction = function(kind) {
            var ctx = pendingCtx || {};
            var courseid = courseIdFromContext();
            if (!courseid) {
                if (window.console && console.warn) {
                    console.warn('[istikama] No courseid — cannot open picker.');
                }
                hideModal();
                return;
            }
            var params = new URLSearchParams();
            params.set('courseid', courseid);
            if (ctx.sectionnum) { params.set('sectionnum', ctx.sectionnum); }
            if (ctx.sectionid)  { params.set('sectionid',  ctx.sectionid); }
            if (ctx.beforemod)  { params.set('beforemod',  ctx.beforemod); }
            var pages = {
                quiz:    '/local/istikama_admin/add_course_quiz.php',
                forum:   '/local/istikama_admin/add_course_forum.php',
                library: '/local/istikama_admin/add_library_content.php',
            };
            window.location.href = (pages[kind] || pages.library) + '?' + params.toString();
        };

        // Capture-phase delegation: fires before any of Moodle's own
        // listeners and works for buttons rendered after page load.
        var interceptClick = function(e) {
            if (!e || !e.target || !e.target.closest) { return; }
            var btn = e.target.closest('[data-action="open-chooser"]');
            if (!btn) { return; }
            e.preventDefault();
            e.stopPropagation();
            if (e.stopImmediatePropagation) { e.stopImmediatePropagation(); }
            showModal({
                sectionnum: btn.getAttribute('data-sectionnum') || '',
                sectionid:  btn.getAttribute('data-section-id') || '',
                beforemod:  btn.getAttribute('data-beforemod') || '',
            });
        };
        // Listen on both document and body, capture phase, for maximum priority.
        document.addEventListener('click',      interceptClick, true);
        document.addEventListener('mousedown',  interceptClick, true);
    });

    // ──────────────────────────────────────────────────────────────
    // Redirect resource/url activity clicks to the Istikama content
    // viewer (view_content.php) for a richer YouTube / PDF experience.
    // ──────────────────────────────────────────────────────────────
    safeRun(function() {
        // Skip if we're already in the viewer to avoid redirect loops.
        if (/\/local\/istikama_admin\/view_content\.php/.test(window.location.pathname)) { return; }
        document.addEventListener('click', function(e) {
            if (!e || !e.target || !e.target.closest) { return; }
            var link = e.target.closest('a[href]');
            if (!link) { return; }
            var href = link.href || '';
            var m = href.match(/\/mod\/(url|resource)\/view\.php[^?]*\?(?:.*&)?id=(\d+)/);
            if (!m) { return; }
            e.preventDefault();
            e.stopPropagation();
            window.location.href = '/local/istikama_admin/view_content.php?cmid=' + m[2];
        }, false);

        // Also intercept direct navigation to mod/url or mod/resource if user
        // somehow lands there (e.g. from a bookmarked link).
        var path = window.location.pathname;
        var direct = path.match(/\/mod\/(url|resource)\/view\.php$/);
        if (direct) {
            var params = new URLSearchParams(window.location.search);
            var cmid = params.get('id');
            if (cmid) {
                window.location.replace('/local/istikama_admin/view_content.php?cmid=' + cmid);
            }
        }
    });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', boot);
    } else {
        boot();
    }
})();
</script>

{{{ output.standard_end_of_body_html }}}

</body>
