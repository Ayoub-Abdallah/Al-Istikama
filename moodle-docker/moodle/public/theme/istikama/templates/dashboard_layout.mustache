<!-- ═══ GLOBAL SEARCH (permission-aware dropdown) ═══ -->
<script>
(function(){
  var input = document.getElementById('istiGlobalSearch');
  var dd    = document.getElementById('istiSearchDropdown');
  var wrap  = document.getElementById('istiSearchWrap');
  var spin  = document.getElementById('istiSearchSpinner');
  if(!input || !dd) return;

  var SEARCH_URL = '/local/istikama_admin/search.php';
  var STR = {
    recent:   {{#quote}}{{#str}}search_recent, local_istikama_admin{{/str}}{{/quote}},
    none:     {{#quote}}{{#str}}search_no_results, local_istikama_admin{{/str}}{{/quote}},
    clear:    {{#quote}}{{#str}}search_clear_recent, local_istikama_admin{{/str}}{{/quote}}
  };
  var CATS = {
    pages:   {{#quote}}{{#str}}search_cat_pages, local_istikama_admin{{/str}}{{/quote}},
    users:   {{#quote}}{{#str}}search_cat_users, local_istikama_admin{{/str}}{{/quote}},
    courses: {{#quote}}{{#str}}search_cat_courses, local_istikama_admin{{/str}}{{/quote}},
    admin:   {{#quote}}{{#str}}search_cat_admin, local_istikama_admin{{/str}}{{/quote}}
  };
  var RECENT_KEY = 'isti-search-recent';
  var timer=null, lastQ='', items=[], active=-1, open=false;

  function esc(s){ var d=document.createElement('div'); d.textContent=(s==null?'':String(s)); return d.innerHTML; }
  function getRecent(){ try{ return JSON.parse(localStorage.getItem(RECENT_KEY)||'[]'); }catch(e){ return []; } }
  function pushRecent(it){ try{ var r=getRecent().filter(function(x){return x.url!==it.url;}); r.unshift({label:it.label,url:it.url,icon:it.icon}); localStorage.setItem(RECENT_KEY, JSON.stringify(r.slice(0,5))); }catch(e){} }
  function clearRecent(){ try{ localStorage.removeItem(RECENT_KEY); }catch(e){} renderRecent(); }

  function setOpen(v){ open=v; wrap.classList.toggle('isti-search-open', v); input.setAttribute('aria-expanded', v?'true':'false'); }
  function close(){ setOpen(false); active=-1; }

  function row(it, idx, cat){
    return '<a class="isti-search-item" role="option" data-idx="'+idx+'" href="'+esc(it.url)+'">'+
      '<span class="isti-search-ic"><i class="fa '+esc(it.icon||'fa-arrow-right')+'"></i></span>'+
      '<span class="isti-search-tx"><span class="isti-search-lbl">'+esc(it.label)+'</span>'+
      (it.sublabel?'<span class="isti-search-sub">'+esc(it.sublabel)+'</span>':'')+'</span></a>';
  }

  function renderResults(results){
    items = results;
    if(!results.length){ dd.innerHTML='<div class="isti-search-empty"><i class="fa fa-magnifying-glass"></i> '+esc(STR.none)+'</div>'; setOpen(true); return; }
    var html='', cat=null, idx=0;
    results.forEach(function(it){
      if(it.category!==cat){ cat=it.category; html+='<div class="isti-search-cat">'+esc(CATS[cat]||cat)+'</div>'; }
      html+=row(it, idx, cat); idx++;
    });
    dd.innerHTML=html; active=-1; setOpen(true); bindRows();
  }

  function renderRecent(){
    var r=getRecent();
    if(!r.length){ return false; }
    items=r;
    var html='<div class="isti-search-cat">'+esc(STR.recent)+'<button type="button" class="isti-search-clear" id="istiSearchClear">'+esc(STR.clear)+'</button></div>';
    r.forEach(function(it,i){ html+=row(it,i,'recent'); });
    dd.innerHTML=html; active=-1; setOpen(true); bindRows();
    var cb=document.getElementById('istiSearchClear'); if(cb) cb.addEventListener('click',function(e){ e.preventDefault(); e.stopPropagation(); clearRecent(); });
    return true;
  }

  function bindRows(){
    dd.querySelectorAll('.isti-search-item').forEach(function(a){
      a.addEventListener('mousedown', function(e){ e.preventDefault(); pushRecent(items[parseInt(a.getAttribute('data-idx'),10)]); window.location.href=a.getAttribute('href'); });
      a.addEventListener('mouseenter', function(){ active=parseInt(a.getAttribute('data-idx'),10); paint(); });
    });
  }
  function paint(){ dd.querySelectorAll('.isti-search-item').forEach(function(a){ a.classList.toggle('active', parseInt(a.getAttribute('data-idx'),10)===active); }); }

  function doSearch(q){
    if(spin) spin.classList.add('on');
    fetch(SEARCH_URL+'?q='+encodeURIComponent(q), {credentials:'same-origin'})
      .then(function(r){return r.json();})
      .then(function(d){ if(spin) spin.classList.remove('on'); if(input.value.trim()===q){ renderResults((d&&d.results)||[]); } })
      .catch(function(){ if(spin) spin.classList.remove('on'); });
  }

  input.addEventListener('input', function(){
    var q=input.value.trim();
    if(timer) clearTimeout(timer);
    if(q.length<2){ if(!renderRecent()) close(); return; }
    timer=setTimeout(function(){ if(q!==lastQ){ lastQ=q; } doSearch(q); }, 220);
  });
  input.addEventListener('focus', function(){ var q=input.value.trim(); if(q.length>=2){ if(items.length) setOpen(true); else doSearch(q); } else { renderRecent(); } });
  input.addEventListener('keydown', function(e){
    if(!open) return;
    var n=dd.querySelectorAll('.isti-search-item').length;
    if(e.key==='ArrowDown'){ e.preventDefault(); active=Math.min(active+1,n-1); paint(); scrollTo(); }
    else if(e.key==='ArrowUp'){ e.preventDefault(); active=Math.max(active-1,0); paint(); scrollTo(); }
    else if(e.key==='Enter'){ if(active>=0&&items[active]){ e.preventDefault(); pushRecent(items[active]); window.location.href=items[active].url; } }
    else if(e.key==='Escape'){ close(); input.blur(); }
  });
  function scrollTo(){ var el=dd.querySelector('.isti-search-item.active'); if(el&&el.scrollIntoView) el.scrollIntoView({block:'nearest'}); }

  document.addEventListener('click', function(e){ if(!wrap.contains(e.target)) close(); });
})();
</script>

