<script>
/* Apply dark-mode preference synchronously to avoid a flash of light content.
   ── TEMPORARILY DISABLED (2026-06) alongside the hidden dark-mode toggle ──
   The dark-mode CSS + toggle JS are all preserved. To fully restore dark mode,
   un-comment the line below AND remove style="display:none" hidden from the
   #istiDarkModeToggle button later in this file. Nothing else is needed. */
/* (function(){ try { if (localStorage.getItem('isti-dark-mode') === '1') { document.body.classList.add('dark-mode'); } } catch(e) {} })(); */

/* Global safety net for legacy Moodle / 3rd-party JS that calls
   addEventListener on null elements (boost drawer, block-level tour init,
   etc.). We log but never let the dashboard die because of these. */
(function() {
    window.addEventListener('error', function(e) {
        var msg = e && e.message ? String(e.message) : '';
        if (msg.indexOf("Cannot read properties of null") !== -1 ||
            msg.indexOf("Cannot read property 'addEventListener'") !== -1 ||
            msg.indexOf("null is not an object") !== -1) {
            if (window.console && console.warn) {
                console.warn('[istikama] Suppressed dashboard JS error:', msg, e.filename + ':' + e.lineno);
            }
            e.preventDefault();
            return true;
        }
    }, true);
    window.addEventListener('unhandledrejection', function(e) {
        if (window.console && console.warn) {
            console.warn('[istikama] Unhandled promise rejection (suppressed):', e.reason);
        }
        e.preventDefault();
    });
})();
</script>
