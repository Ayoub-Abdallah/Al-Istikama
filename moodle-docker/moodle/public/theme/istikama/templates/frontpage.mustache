/* ── Language switcher: globe + dropdown (dark, professional) ── */
#landing-page .ld-lang{position:relative}
#landing-page .ld-lang-toggle{display:inline-flex;align-items:center;gap:7px;border:1.5px solid rgba(20,28,46,.18);background:rgba(20,28,46,.04);color:#1e293b !important;border-radius:10px;padding:8px 13px;font-size:.78rem;font-weight:700;cursor:pointer;transition:.18s}
#landing-page .ld-lang-toggle i{color:#1e293b}
#landing-page .ld-lang-toggle:hover{border-color:var(--ld-gold);background:rgba(240,165,0,.08)}
#landing-page .ld-lang-toggle .fa-chevron-down{font-size:.58rem;opacity:.7;transition:transform .2s}
#landing-page .ld-lang.open .ld-lang-toggle .fa-chevron-down{transform:rotate(180deg)}
#landing-page .ld-lang-menu{position:absolute;top:calc(100% + 8px);inset-inline-end:0;min-width:158px;background:#fff;border:1px solid #e8e8ee;border-radius:12px;box-shadow:0 18px 44px -14px rgba(15,23,42,.35);padding:6px;opacity:0;visibility:hidden;transform:translateY(-6px);transition:.18s;z-index:60}
#landing-page .ld-lang.open .ld-lang-menu{opacity:1;visibility:visible;transform:none}
#landing-page .ld-lang-menu button{display:flex;align-items:center;gap:10px;width:100%;border:0;background:transparent;color:#1e293b;font-family:'Montserrat','Noto Sans Arabic',sans-serif;font-size:.84rem;font-weight:600;padding:9px 11px;border-radius:8px;cursor:pointer;text-align:start}
#landing-page .ld-lang-menu button:hover{background:#f4f5f8}
#landing-page .ld-lang-menu button.on{background:var(--ld-gold);color:#fff}
#landing-page .ld-lang-menu button .flag{font-size:.72rem;font-weight:800;opacity:.55;min-width:20px}
#landing-page .ld-lang-menu button.on .flag{opacity:.9}
#landing-page .ld-mobile .ld-lang{margin:8px 0}
#landing-page .ld-mobile .ld-lang-toggle{width:100%;justify-content:center;color:#1e293b}

/* ── Join CTA band (above footer) — rich, ornamented ── */
#landing-page .ld-join{position:relative;overflow:hidden;background:linear-gradient(120deg,#10182b 0%,#1b2a47 55%,#243760 100%);padding:78px 0}
#landing-page .ld-join::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 16% 130%,rgba(240,165,0,.22),transparent 42%),radial-gradient(circle at 94% -25%,rgba(240,165,0,.13),transparent 40%);pointer-events:none}
#landing-page .ld-join-zk{position:absolute;pointer-events:none;width:340px;max-width:36vw;opacity:.07;filter:brightness(0) invert(1);z-index:1}
/* Physical left/right so the ornaments never flip in RTL (Arabic) */
#landing-page .ld-join-zk.tl{top:-34px;left:-24px;right:auto}
#landing-page .ld-join-zk.br{bottom:-44px;right:-24px;left:auto;transform:rotate(180deg)}
#landing-page.ld-rtl .ld-join-zk.tl{left:-24px;right:auto}
#landing-page.ld-rtl .ld-join-zk.br{right:-24px;left:auto}
#landing-page .ld-join .inner{position:relative;z-index:2;display:flex;align-items:center;justify-content:space-between;gap:36px;flex-wrap:wrap}
