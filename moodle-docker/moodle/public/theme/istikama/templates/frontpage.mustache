    var lp = document.getElementById('landing-page');
    function applyLang(lang) {
        var dict = I18N[lang] || I18N.en;
        lp.querySelectorAll('[data-i18n]').forEach(function (el) {
            var k = el.getAttribute('data-i18n'); if (dict[k] != null) el.textContent = dict[k];
        });
        lp.querySelectorAll('[data-i18n-html]').forEach(function (el) {
            var k = el.getAttribute('data-i18n-html'); if (dict[k] != null) el.innerHTML = dict[k];
        });
        lp.querySelectorAll('[data-i18n-ph]').forEach(function (el) {
            var k = el.getAttribute('data-i18n-ph'); if (dict[k] != null) el.setAttribute('placeholder', dict[k]);
        });
        lp.setAttribute('lang', lang);
        lp.setAttribute('dir', lang === 'ar' ? 'rtl' : 'ltr');
        lp.classList.toggle('ld-rtl', lang === 'ar');
        var labels = { en: 'EN', fr: 'FR', ar: 'العربية' };
        document.querySelectorAll('#landing-page .ld-lang-label').forEach(function (el) { el.textContent = labels[lang] || 'EN'; });
        document.querySelectorAll('#landing-page .ld-lang-menu [data-lang]').forEach(function (b) {
            b.classList.toggle('on', b.getAttribute('data-lang') === lang);
        });
        try { localStorage.setItem('isti-landing-lang', lang); } catch (e) {}
    }
    // Dropdown open/close + selection
    document.querySelectorAll('#landing-page .ld-lang').forEach(function (box) {
        var toggle = box.querySelector('.ld-lang-toggle');
        if (toggle) toggle.addEventListener('click', function (e) {
            e.stopPropagation();
            var willOpen = !box.classList.contains('open');
            document.querySelectorAll('#landing-page .ld-lang.open').forEach(function (o) { o.classList.remove('open'); });
            box.classList.toggle('open', willOpen);
        });
        box.querySelectorAll('.ld-lang-menu [data-lang]').forEach(function (btn) {
            btn.addEventListener('click', function () { applyLang(btn.getAttribute('data-lang')); box.classList.remove('open'); });
        });
    });
    document.addEventListener('click', function () {
        document.querySelectorAll('#landing-page .ld-lang.open').forEach(function (o) { o.classList.remove('open'); });
    });
    var saved = 'en';
    try { saved = localStorage.getItem('isti-landing-lang') || 'en'; } catch (e) {}
    if (saved !== 'en') applyLang(saved);

    // ── Sticky nav shadow ──
    var nav = document.getElementById('ldNav');
    var totop = document.getElementById('ldTotop');
    function onScroll() {
        var y = window.pageYOffset || document.documentElement.scrollTop;
        if (nav) nav.classList.toggle('scrolled', y > 30);
        if (totop) totop.classList.toggle('show', y > 600);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // ── Mobile menu ──
    var burger = document.getElementById('ldHamburger');
    var mobile = document.getElementById('ldMobile');
    if (burger && mobile) {
        burger.addEventListener('click', function () {
            var open = mobile.classList.toggle('open');
            burger.innerHTML = open ? '<i class="fa-solid fa-xmark"></i>' : '<i class="fa-solid fa-bars"></i>';
        });
        mobile.querySelectorAll('a').forEach(function (a) {
            a.addEventListener('click', function () {
                mobile.classList.remove('open');
                burger.innerHTML = '<i class="fa-solid fa-bars"></i>';
            });
        });
    }

    // ── Smooth in-page anchor scroll ──
    document.querySelectorAll('#landing-page a[href^="#"]').forEach(function (a) {
        a.addEventListener('click', function (e) {
            var id = a.getAttribute('href');
            if (id.length < 2) return;
            var t = document.querySelector(id);
            if (!t) return;
            e.preventDefault();
            var top = t.getBoundingClientRect().top + window.pageYOffset - 70;
            window.scrollTo({ top: top, behavior: 'smooth' });
        });
    });

    // ── Back to top ──
    if (totop) totop.addEventListener('click', function () { window.scrollTo({ top: 0, behavior: 'smooth' }); });

    // ── Feature-tag selector (visual) ──
    var amounts = document.getElementById('ldAmounts');
    if (amounts) amounts.addEventListener('click', function (e) {
        var b = e.target.closest('.ld-amount');
        if (!b) return;
        amounts.querySelectorAll('.ld-amount').forEach(function (x) { x.classList.remove('active'); });
        b.classList.add('active');
    });

    // ── Scroll-reveal via IntersectionObserver (with hard safety net) ──
    var revealEls = document.querySelectorAll('#landing-page [data-reveal]');
    function reveal(el) {
        if (el.classList.contains('in')) return;
        el.classList.add('in');
        el.querySelectorAll('.ld-progress .fill').forEach(function (f) {
            var p = f.getAttribute('data-pct') || 0;
            requestAnimationFrame(function () { f.style.width = p + '%'; });
        });
    }
    if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (en) {
                if (en.isIntersecting) { reveal(en.target); io.unobserve(en.target); }
            });
        }, { threshold: 0.08, rootMargin: '0px 0px -6% 0px' });
        revealEls.forEach(function (el) { io.observe(el); });
        requestAnimationFrame(function () {
            revealEls.forEach(function (el) {
                var r = el.getBoundingClientRect();
                if (r.top < window.innerHeight && r.bottom > 0) reveal(el);
            });
        });
        setTimeout(function () {
            revealEls.forEach(function (el) {
                var r = el.getBoundingClientRect();
                if (r.top < window.innerHeight * 1.5) reveal(el);
            });
        }, 1200);
        setTimeout(function () { revealEls.forEach(reveal); }, 3000);
        var passTick = false;
        window.addEventListener('scroll', function () {
            if (passTick) return; passTick = true;
            requestAnimationFrame(function () {
                passTick = false;
                revealEls.forEach(function (el) {
                    if (el.classList.contains('in')) return;
                    var r = el.getBoundingClientRect();
                    if (r.top < window.innerHeight * 0.95) reveal(el);
                });
            });
        }, { passive: true });
    } else {
        revealEls.forEach(reveal);
    }
})();
</script>

