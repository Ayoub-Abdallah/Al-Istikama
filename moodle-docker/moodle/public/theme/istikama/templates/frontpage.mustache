#landing-page .ld-join p{color:rgba(255,255,255,.78);margin:0;font-size:1.02rem;max-width:560px;line-height:1.7}
#landing-page .ld-join .acts{display:flex;gap:14px;flex-wrap:wrap;flex-shrink:0}
