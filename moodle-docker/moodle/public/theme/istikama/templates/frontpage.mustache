#landing-page p,#landing-page a,#landing-page span,#landing-page li,#landing-page .ld-title,#landing-page .name,
#landing-page .cap,#landing-page .role,#landing-page .desc,#landing-page .excerpt,#landing-page .ld-eyebrow,
