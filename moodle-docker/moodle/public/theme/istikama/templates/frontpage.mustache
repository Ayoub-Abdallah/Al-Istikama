@keyframes ldHeroUp{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:none}}
#landing-page .ld-hero .accent{background:linear-gradient(100deg,var(--ld-gold) 0%,#ffd87a 45%,var(--ld-gold) 90%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
