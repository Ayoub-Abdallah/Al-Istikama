cademic Seasons";s:21:"current_active_season";s:21:"Current active season";s:16:"no_active_season";s:24:"No active season is set.";s:21:"no_active_season_help";s:139:"New attendance, assessment, and promotion data will not be stamped with a season until one is activated. Create or activate a season below.";s:11:"all_seasons";s:11:"All seasons";s:10:"new_season";s:10:"New season";s:11:"season_name";s:4:"Name";s:18:"season_description";s:11:"Description";s:17:"season_start_date";s:10:"Start date";s:15:"season_end_date";s:8:"End date";s:13:"season_status";s:6:"Status";s:14:"no_seasons_yet";s:60:"No seasons defined yet. Create the first one to get started.";s:13:"mark_upcoming";s:13:"Mark upcoming";s:8:"activate";s:8:"Activate";s:7:"archive";s:7:"Archive";s:12:"close_season";s:5:"Close";s:10:"reactivate";s:11:"Re-activate";s:6:"locked";s:6:"Locked";s:16:"confirm_activate";s:76:"Activate this season? The currently active season (if any) will be archived.";s:15:"confirm_archive";s:66:"Archive this season? Writes to season-scoped data will be blocked.";s:13:"confirm_close";s:92:"Permanently close this season? This cannot be undone — no further writes will be possible.";s:18:"confirm_reactivate";s:79:"Re-activate this archived season? The currently active season will be archived.";s:21:"confirm_delete_season";s:55:"Delete this draft season? This action cannot be undone.";s:4:"save";s:4:"Save";s:14:"season_created";s:15:"Season created.";s:14:"season_updated";s:15:"Season updated.";s:16:"season_activated";s:17:"Season activated.";s:15:"season_archived";s:16:"Season archived.";s:13:"season_closed";s:26:"Season closed permanently.";s:22:"season_marked_upcoming";s:26:"Season marked as upcoming.";s:13:"reopen_season";s:6:"Reopen";s:14:"confirm_reopen";s:97:"Reopen this closed season as the active one? Only allowed if no other season is currently active.";s:15:"season_reopened";s:34:"Season reopened and set as active.";s:21:"season_already_active";s:66:"Cannot activate: another season is already active. Close it first.";s:26:"season_close_name_mismatch";s:52:"The typed name did not match. Season was not closed.";s:17:"archived_terminal";s:20:"Archived (read-only)";s:24:"no_active_season_blocked";s:75:"No active season — actions are blocked until an admin activates a season.";s:23:"task_auto_close_seasons";s:35:"Auto-close expired Istikama seasons";s:20:"season_dates_overlap";s:75:"Date range overlaps with another season ({$a}). Seasons must not intersect.";s:18:"season_end_in_past";s:80:"The active season's end date cannot be moved into the past. Pick today or later.";s:11:"edit_season";s:11:"Edit season";s:23:"season_active_edit_note";s:98:"This is the active season. You can edit any field, but the end date cannot be moved into the past.";s:14:"season_deleted";s:15:"Season deleted.";s:16:"season_immutable";s:57:"This season is closed or archived — writes are blocked.";s:20:"season_name_required";s:24:"Season name is required.";s:20:"season_name_too_long";s:45:"Season name is too long (max 100 characters).";s:21:"season_dates_required";s:38:"Both start and end dates are required.";s:23:"season_end_before_start";s:34:"End date must be after start date.";s:17:"season_name_taken";s:39:"A season with that name already exists.";s:29:"season_transition_not_allowed";s:46:"Season status transition is not allowed: {$a}.";s:23:"season_delete_not_draft";s:122:"Only draft or upcoming seasons can be deleted. Active seasons must be closed first; closed/archived seasons are read-only.";s:15:"confirm_close_q";s:13:"Close season?";s:18:"confirm_close_help";s:150:"This action ends the active season. No further actions will be possible on the platform until a new season is activated. All season data is preserved.";s:22:"confirm_close_typename";s:20:"Type the season name";s:22:"season_delete_has_data";s:53:"Cannot delete: data is already linked to this season.";s:20:"season_start_in_past";s:40:"Season start date cannot be in the past.";s:22:"season_not_started_yet";s:123:"Cannot activate: this season has not started yet. Activation is only allowed once the season's start date has been reached.";s:14:"restore_season";s:7:"Restore";s:15:"confirm_restore";s:121:"Restore this season from archive? It will be set to Closed status. You can then Reopen it as the active season if needed.";s:15:"season_restored";s:29:"Season restored from archive.";s:13:"manage_levels";s:15:"Academic Levels";s:13:"global_levels";s:22:"Global academic levels";s:18:"global_levels_help";s:111:"Define the levels offered across the platform. Schools then choose which ones they offer in their own settings.";s:9:"new_level";s:9:"New level";s:10:"level_name";s:4:"Name";s:10:"level_tier";s:4:"Tier";s:12:"tier_primary";s:7:"Primary";s:11:"tier_middle";s:6:"Middle";s:9:"tier_high";s:11:"High School";s:6:"levels";s:8:"level(s)";s:17:"no_levels_in_tier";s:36:"No levels defined for this tier yet.";s:7:"move_up";s:7:"Move up";s:9:"move_down";s:9:"Move down";s:13:"level_renamed";s:14:"Level renamed.";s:15:"level_reordered";s:16:"Level reordered.";s:13:"level_deleted";s:14:"Level deleted.";s:19:"level_name_required";s:23:"Level name is required.";s:12:"invalid_tier";s:19:"Invalid tier value.";s:25:"level_delete_has_subjects";s:73:"Cannot delete: this level still has subjects assigned. Remove them first.";s:27:"level_delete_has_categories";s:95:"Cannot delete: this level is in use by one or more schools. Detach it from those schools first.";s:23:"level_delete_has_school";s:96:"Cannot delete: this level is still assigned to one or more schools. Remove the assignment first.";s:20:"confirm_delete_level";s:48:"Delete this level? This action cannot be undone.";s:17:"manage_promotions";s:18:"Student Promotions";s:22:"promotion_step_seasons";s:48:"Step 1 — Choose source and destination seasons";s:20:"promotion_step_class";s:30:"Step 2 — Choose source class";s:26:"promotion_step_destination";s:49:"Step 3 — Pick destination, action, and students";s:21:"promotion_from_season